# SafetyHub Gateway — Environment Variables
# Copy this file to .env and fill in your values.

# ESP32 local API (do not change unless you rewired the ESP32)
ESP32_URL=http://192.168.4.1/api/data

# Your deployed cloud backend URL
# Change this to your Render URL after deploying
BACKEND_URL=https://safetyhub-backend.onrender.com

# How often to poll ESP32 (seconds)
POLL_INTERVAL=2.0

# Local gateway API port (for debugging)
GATEWAY_PORT=8001

# SafetyHub Dashboard — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
#
# ── CLOUD MODE (recommended — anyone can view the dashboard) ──
# Set this to your deployed Render backend URL.
# Once set, the dashboard reads from the cloud — no ESP32 WiFi needed.
VITE_CLOUD_BACKEND_URL=https://safetyhub-backend.onrender.com

# ── LOCAL MODE (fallback — only works on ESP32 WiFi) ──────────
# Comment out VITE_CLOUD_BACKEND_URL above to use local mode.
# The dashboard will poll ESP32 directly at 192.168.4.1.
# This only works when your device is connected to SafetyHub WiFi.
